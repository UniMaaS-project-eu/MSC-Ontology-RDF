@prefix sc: <http://example.com/MSCOnto#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

# ===== PRODUCTS =====

<http://example.com/product/PROD001> a sc:EndProduct ;
    sc:id "PROD001" ;
    sc:name "Luxury Seat V5" ;
    sc:hasComponent <http://example.com/product/PROD101> ;
    sc:hasComponent <http://example.com/product/PROD102> ;
    sc:hasComponent <http://example.com/product/PROD103> ;
    sc:satisfiesRequirement <http://example.com/requirement/REQ001> ;
    sc:satisfiesRequirement <http://example.com/requirement/REQ002> ;
    sc:satisfiesRequirement <http://example.com/requirement/REQ003> .

<http://example.com/product/PROD101> a sc:IntermediaryProduct ;
    sc:id "PROD101" ;
    sc:name "Memory Foam Core" ;
    sc:isComponentOf <http://example.com/product/PROD001> ;
    sc:satisfiesRequirement <http://example.com/requirement/REQ001> ;
    sc:isProductOf <http://example.com/processconfig/CONF002> ;
    sc:inputsProduct <http://example.com/processconfig/CONF008> .

<http://example.com/product/PROD102> a sc:IntermediaryProduct ;
    sc:id "PROD102" ;
    sc:name "Leather Trim Cover" ;
    sc:isComponentOf <http://example.com/product/PROD001> ;
    sc:satisfiesRequirement <http://example.com/requirement/REQ003> ;
    sc:isProductOf <http://example.com/processconfig/CONF004> ;
    sc:inputsProduct <http://example.com/processconfig/CONF008> .

<http://example.com/product/PROD103> a sc:IntermediaryProduct ;
    sc:id "PROD103" ;
    sc:name "Power Adjustable Frame" ;
    sc:isComponentOf <http://example.com/product/PROD001> ;
    sc:satisfiesRequirement <http://example.com/requirement/REQ002> ;
    sc:isProductOf <http://example.com/processconfig/CONF007> ;
    sc:inputsProduct <http://example.com/processconfig/CONF008> .

<http://example.com/product/PROD104> a sc:IntermediaryProduct ;
    sc:id "PROD104" ;
    sc:name "Memory Foam Fluffed" ;
    sc:isProductOf <http://example.com/processconfig/CONF001> ;
    sc:inputsProduct <http://example.com/processconfig/CONF002> .

<http://example.com/product/PROD105> a sc:IntermediaryProduct ;
    sc:id "PROD105" ;
    sc:name "Leather Cut" ;
    sc:isProductOf <http://example.com/processconfig/CONF003> ;
    sc:inputsProduct <http://example.com/processconfig/CONF004> .

<http://example.com/product/PROD106> a sc:IntermediaryProduct ;
    sc:id "PROD106" ;
    sc:name "Welded Frame" ;
    sc:isProductOf <http://example.com/processconfig/CONF005> ;
    sc:inputsProduct <http://example.com/processconfig/CONF006> .

<http://example.com/product/PROD107> a sc:IntermediaryProduct ;
    sc:id "PROD107" ;
    sc:name "Powered Welded Frame" ;
    sc:isProductOf <http://example.com/processconfig/CONF006> ;
    sc:inputsProduct <http://example.com/processconfig/CONF007> .

# ===== CUSTOMER REQUIREMENTS =====

<http://example.com/requirement/REQ001> a sc:CustomerRequirement ;
    sc:id "REQ001" ;
    sc:name "Ventilated Seat" ;
    sc:isSatisfiedBy <http://example.com/product/PROD001> ;
    sc:isSatisfiedBy <http://example.com/product/PROD101> .

<http://example.com/requirement/REQ002> a sc:CustomerRequirement ;
    sc:id "REQ002" ;
    sc:name "Power Adjustment" ;
    sc:isSatisfiedBy <http://example.com/product/PROD001> ;
    sc:isSatisfiedBy <http://example.com/product/PROD103> .

<http://example.com/requirement/REQ003> a sc:CustomerRequirement ;
    sc:id "REQ003" ;
    sc:name "Leather Upholstery" ;
    sc:isSatisfiedBy <http://example.com/product/PROD001> ;
    sc:isSatisfiedBy <http://example.com/product/PROD102> .

