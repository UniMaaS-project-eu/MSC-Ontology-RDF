@prefix sc: <http://example.com/MSCOnto#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

# ===== CLASS DEFINITIONS =====
sc:ConfigurableEntity a owl:Class ;
    rdfs:label "Configurable Entity" ;
    rdfs:comment "Base class for entities that have properties" .

sc:Product a owl:Class ;
    rdfs:label "Product" ;
    rdfs:comment "Product that is the output of a manufacturing process and maybe input to another process" .

sc:CustomerRequirement a owl:Class ;
    rdfs:label "Customer Requirement" ;
    rdfs:comment "Specifications required by customer" .

sc:ProcessConfiguration a owl:Class ;
    rdfs:label "Process Configuration" ;
    rdfs:comment "Configuration of a manufacturing process that binds the specific input and output parameters" .

sc:Process a owl:Class ;
    rdfs:label "Process" ;
    rdfs:comment "Manufacturing, assembly or virtual process" .

sc:Resource a owl:Class ;
    rdfs:label "Resource" ;
    rdfs:comment "Needed material, workforce, software, etc. resource to perform processes" .

sc:Supplier a owl:Class ;
    rdfs:label "Supplier" ;
    rdfs:comment "Supplier of resources" .

sc:Site a owl:Class ;
    rdfs:label "Manufacturing Site" ;
    rdfs:comment "Physical location where processes are performed" .

sc:Device a owl:Class ;
    rdfs:label "Device" ;
    rdfs:comment "Equipment or machinery at a site" .

sc:Property a owl:Class ;
    rdfs:label "Property" ;
    rdfs:comment "Characteristic or attribute of resource/device/site/supplier" .

sc:Sensor a owl:Class ;
    rdfs:label "Sensor" ;
    rdfs:comment "Measurement device" .

sc:LogisticRoute a owl:Class ;
    rdfs:label "Logistic Route" ;
    rdfs:comment "Transportation route between locations" .

sc:Location a owl:Class ;
    rdfs:label "Location" ;
    rdfs:comment "Physical geographic location" .

sc:Device rdfs:subClassOf sc:ConfigurableEntity .
sc:Site rdfs:subClassOf sc:ConfigurableEntity .
sc:Supplier rdfs:subClassOf sc:ConfigurableEntity .
sc:Resource rdfs:subClassOf sc:ConfigurableEntity .
sc:Process rdfs:subClassOf sc:ConfigurableEntity .
sc:Product rdfs:subClassOf sc:ConfigurableEntity .

# ===== OBJECT PROPERTIES =====

sc:satisfiesRequirement a owl:ObjectProperty ;
    rdfs:label "satisfies requirement" ;
    rdfs:domain sc:Product ;
    rdfs:range sc:CustomerRequirement .

sc:hasComponent a owl:ObjectProperty ;
    owl:transitiveProperty true ;
    rdfs:label "has component" ;
    rdfs:domain sc:Product ;
    rdfs:range sc:Product .

sc:requiresProcess a owl:ObjectProperty ;
    rdfs:label "requires process" ;
    rdfs:domain sc:ProcessConfiguration ;
    rdfs:range sc:Process .

sc:usesResource a owl:ObjectProperty ;
    rdfs:label "uses resource" ;
    rdfs:domain sc:ProcessConfiguration ;
    rdfs:range sc:Resource .

sc:hasOutput a owl:ObjectProperty ;
    rdfs:label "has output" ;
    rdfs:domain sc:ProcessConfiguration ;
    rdfs:range sc:Product .

sc:hasInput a owl:ObjectProperty ;
    rdfs:label "has input" ;
    rdfs:domain sc:ProcessConfiguration ;
    rdfs:range sc:Product .

sc:hasPreviousStep a owl:ObjectProperty ;
    rdfs:label "has previous step" ;
    rdfs:domain sc:ProcessConfiguration ;
    rdfs:range sc:ProcessConfiguration ;
    owl:inverseOf sc:hasNextStep .

sc:hasNextStep a owl:ObjectProperty ;
    rdfs:label "has next step" ;
    rdfs:domain sc:ProcessConfiguration ;
    rdfs:range sc:ProcessConfiguration ;
    owl:inverseOf sc:hasPreviousStep .

sc:isProvidedBy a owl:ObjectProperty ;
    rdfs:label "is provided by" ;
    rdfs:domain sc:Resource ;
    rdfs:range sc:Supplier ;
    owl:inverseOf sc:provides .

sc:provides a owl:ObjectProperty ;
    rdfs:label "provides" ;
    rdfs:domain sc:Supplier ;
    rdfs:range sc:Resource ;
    owl:inverseOf sc:isProvidedBy .

sc:isPerformedAt a owl:ObjectProperty ;
    rdfs:label "is performed at" ;
    rdfs:domain sc:Process ;
    rdfs:range sc:Site ;
    owl:inverseOf sc:performs .

sc:performs a owl:ObjectProperty ;
    rdfs:label "performs" ;
    rdfs:domain sc:Site ;
    rdfs:range sc:Process ;
    owl:inverseOf sc:isPerformedAt .

sc:hasDevice a owl:ObjectProperty ;
    rdfs:label "has device" ;
    rdfs:domain sc:Site ;
    rdfs:range sc:Device .

sc:hasProperty a owl:ObjectProperty ;
    rdfs:label "has property" ;
    rdfs:domain sc:ConfigurableEntity ;
    rdfs:range sc:Property .

sc:observes a owl:ObjectProperty ;
    rdfs:label "observes" ;
    rdfs:domain sc:Sensor ;
    rdfs:range sc:Property ;
    owl:inverseOf sc:isObservedBy .

sc:isObservedBy a owl:ObjectProperty ;
    rdfs:label "is observed by" ;
    rdfs:domain sc:Property ;
    rdfs:range sc:Sensor ;
    owl:inverseOf sc:observes .

sc:hasLocation a owl:ObjectProperty ;
    rdfs:label "has location" ;
    rdfs:domain [
        a owl:Class ;
        owl:unionOf (sc:Site sc:Supplier)
    ] ;
    rdfs:range sc:Location .

sc:hasStartingPoint a owl:ObjectProperty ;
    rdfs:label "has starting point" ;
    rdfs:domain sc:LogisticRoute ;
    rdfs:range sc:Location ;
    rdfs:comment "The origin location of the route" .
 
sc:hasEndingPoint a owl:ObjectProperty ;
    rdfs:label "has ending point" ;
    rdfs:domain sc:LogisticRoute ;
    rdfs:range sc:Location ;
    rdfs:comment "The destination location of the route" .

# ===== DATA PROPERTIES =====

sc:id a owl:DatatypeProperty ;
    rdfs:label "identifier" ;
    rdfs:domain owl:Thing ;
    rdfs:range xsd:string .

sc:name a owl:DatatypeProperty ;
    rdfs:label "name" ;
    rdfs:domain owl:Thing ;
    rdfs:range xsd:string .

sc:resourceType a owl:DatatypeProperty ;
    rdfs:label "resource type" ;
    rdfs:domain sc:Resource ;
    rdfs:range xsd:string .

sc:processingRate a owl:DatatypeProperty ;
    rdfs:label "processing rate" ;
    rdfs:domain sc:Site ;
    rdfs:range xsd:decimal .

sc:greenOperationLevel a owl:DatatypeProperty ;
    rdfs:label "green operation level" ;
    rdfs:domain sc:Site ;
    rdfs:range xsd:decimal .

sc:transmissionUnit a owl:DatatypeProperty ;
    rdfs:label "transmission unit" ;
    rdfs:domain sc:LogisticRoute ;
    rdfs:range xsd:string .

sc:transportationMode a owl:DatatypeProperty ;
    rdfs:label "transportation mode" ;
    rdfs:domain sc:LogisticRoute ;
    rdfs:range xsd:string .

sc:transmissionCost a owl:DatatypeProperty ;
    rdfs:label "transmission cost" ;
    rdfs:domain sc:LogisticRoute ;
    rdfs:range xsd:decimal .

sc:sensorValue a owl:DatatypeProperty ;
    rdfs:label "sensor value" ;
    rdfs:domain sc:Sensor ;
    rdfs:range xsd:decimal .

